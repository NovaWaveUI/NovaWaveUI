{
  "name": "@novawaveui/novawaveicon",
  "version": "1.0.0",
  "description": "A re-export of Heroicons to align with NovaWaveUI",
  "type": "module",
  "files": [
    "index.css",
    "dist/"
  ],
  "exports": {
    "./index.css": "./index.css",
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "format": "prettier --write . --config ../../../.prettierrc --ignore-path ../../../.prettierignore",
    "clean:dist": "rm -rf dist",
    "clean:node_modules": "rm -rf node_modules",
    "clean": "pnpm run clean:dist && pnpm run clean:node_modules"
  },
  "keywords": [],
  "author": "Kyle Gagnon",
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@jest/globals": "catalog:",
    "@novawaveui/core": "workspace:*",
    "@novawaveui/eslint-config": "workspace:*",
    "@novawaveui/provider": "workspace:*",
    "@novawaveui/typescript-config": "workspace:*",
    "@novawaveui/vite-config": "workspace:*",
    "@storybook/react": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-variants": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
