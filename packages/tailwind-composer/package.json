{
  "name": "@novawaveui/tailwind-composer",
  "version": "1.2.1",
  "description": "Tailwind Composer is a library that allows you to create complicated Tailwind CSS component variants with ease.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --dts",
    "clean:dist": "rm -rf dist/",
    "clean:node_modules": "rm -rf node_modules/",
    "clean": "pnpm run clean:dist && npm run clean:node_modules",
    "test": "jest --config jest.config.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NovaWaveUI/NovaWaveUI"
  },
  "keywords": [
    "tailwind",
    "variants",
    "css",
    "tailwindcss",
    "utility-first"
  ],
  "author": "Kyle Gagnon <kmgagnon99@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10"
  },
  "dependencies": {
    "tailwind-merge": "^3.0.2"
  }
}
