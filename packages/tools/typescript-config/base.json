{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "composite": false,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "preserveWatchOutput": true,
    "noImplicitAny": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.tests.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx"
  ]
}
