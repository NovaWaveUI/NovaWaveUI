{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "isolatedModules": true,
    "target": "ESNext",
    "module": "ESNext",
    "types": ["@testing-library/jest-dom"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noEmit": false
  },
  "include": [
    "../../packages/components/*/src/**/*",
    "../../packages/core/*/src/**/*",
    "../../packages/utils/*/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "__tests__",
    "**/*.stories.tsx"
  ]
}
