{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["jest", "@testing-library/jest-dom"]
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/__tests__/**",
    "**/*.tests.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx"
  ],
  "include": ["tests/test-setupt.s", "packages"]
}
