{
  "name": "novawaveui",
  "version": "1.0.0",
  "description": "The base of the NovaWaveUI monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:fast": "turbo run build:fast --watch",
    "dev": "turbo run dev --concurrency 13",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "sb": "pnpm --filter @novawaveui/storybook storybook",
    "test": "turbo run test --filter={./packages/components/*} --filter={./packages/core/provider} --filter={./packages/core/core} --filter={./packages/utils/*}",
    "test:watch": "turbo run test:watch --filter={./packages/components/*} --filter={./packages/core/provider} --filter={./packages/core/core} --filter={./packages/utils/*}",
    "test:coverage": "turbo run test:coverage --filter={./packages/components/*} --filter={./packages/core/provider} --filter={./packages/core/core} --filter={./packages/utils/*}",
    "clean:dist": "turbo run clean:dist",
    "clean": "turbo run clean && rm -rf node_modules",
    "create:component": "plop component",
    "create:hook": "plop hook",
    "dev:css": "pnpm --filter @novawaveui/theme build:css --watch"
  },
  "keywords": [
    "novawaveui",
    "react",
    "ui",
    "components",
    "design",
    "system"
  ],
  "author": "Kyle Gagnon <kmgagnon99@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@storybook/blocks": "8.6.0-alpha.0",
    "@storybook/react": "8.6.0-alpha.0",
    "@storybook/test": "^8.6.4",
    "@tailwindcss/vite": "^4.0.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.5",
    "add": "^2.0.6",
    "axe-core": "^4.10.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.20.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "framer-motion": "^12.4.10",
    "jest-axe": "^9.0.0",
    "plop": "^4.0.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.6",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.5"
  }
}
