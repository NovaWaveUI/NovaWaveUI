{
  "name": "novawaveui",
  "version": "1.0.0",
  "description": "The base of the NovaWaveUI monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:fast": "turbo run build:fast --filter='!@novawaveui/storybook' --filter='!@novawaveui/tailwind-composer'",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "sb": "pnpm --filter @novawaveui/storybook storybook",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean:dist": "turbo run clean:dist",
    "clean": "turbo run clean && rm -rf node_modules",
    "create:component": "plop component",
    "create:hook": "plop hook",
    "dev:css": "pnpm --filter @novawaveui/theme build:css --watch",
    "typeCheck": "turbo run typeCheck",
    "prepare": "husky"
  },
  "keywords": [
    "novawaveui",
    "react",
    "ui",
    "components",
    "design",
    "system"
  ],
  "author": "Kyle Gagnon <kmgagnon99@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.20.0",
    "@jest/globals": "^29.7.0",
    "@storybook/blocks": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/test": "^8.6.4",
    "@swc/core": "^1.11.11",
    "@swc/jest": "^0.2.37",
    "@tailwindcss/vite": "^4.0.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.3",
    "add": "^2.0.6",
    "axe-core": "^4.10.2",
    "clean-package": "^2.2.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.3",
    "framer-motion": "^12.4.10",
    "globals": "catalog:",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "plop": "^4.0.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.6",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1"
  }
}
