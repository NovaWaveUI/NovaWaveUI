{
  "name": "@novawaveui/{{hookName}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "keywords": [],
  "author": "Kyle Gagnon <kmgagnon99@gmail.com>",
  "license": "ISC",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts",
    "build:fast": "tsup src/index.ts",
    "dev": "pnpm build:fast --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . --config ../../../.prettierrc --ignore-path ../../../.prettierignore",
    "clean:dist": "rm -rf dist",
    "clean:node_modules": "rm -rf node_modules",
    "clean": "pnpm run clean:dist && pnpm run clean:node_modules",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@novawaveui/eslint-config": "workspace:*",
    "@novawaveui/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "clean-package": "../../../build/clean-package.config.json"
}
